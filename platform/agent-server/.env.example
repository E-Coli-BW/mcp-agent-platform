# ── Agent Server Configuration ─────────────────────────────────────────
# Copy this to .env and customize. Loaded by pydantic-settings (AGENT_ prefix).
# See README.md "Configuration" section for full details.

# ── Models ─────────────────────────────────────────────────────────────
# Main agent — must support tool calling (7B+ recommended)
AGENT_DEFAULT_MODEL=qwen2.5:7b
# Auxiliary tasks — simple text→text, no tools needed (fast 0.5B works)
AGENT_CHEAP_MODEL=mlx/Qwen2.5-0.5B-Instruct-4bit
# MLX server URL (start with: ./scripts/dev/start-mlx.sh)
AGENT_MLX_BASE_URL=http://localhost:8600

# ── Features that USE cheap_model (all off by default) ─────────────────
# Without these enabled, cheap_model is never called and MLX has no effect!

# Reflexion (C1) — grades final answer, retries if quality < min_grade
#AGENT_REFLEXION_ENABLED=true
#AGENT_REFLEXION_MIN_GRADE=3

# LLM Reranking — uses cheap_model for RAG result reranking
# Options: auto | llm | cross_encoder | heuristic | none
#AGENT_RERANK_STRATEGY=llm

# Subagent verifier (C3) — grades child agent answers
#AGENT_SUBAGENT_VERIFIER_ENABLED=true

# ── Provider Keys (for cloud models) ──────────────────────────────────
#AGENT_OPENAI_API_KEY=sk-...
#AGENT_ANTHROPIC_API_KEY=sk-ant-...

# ── Infrastructure ────────────────────────────────────────────────────
#AGENT_REDIS_URL=redis://localhost:6379/0
#AGENT_OLLAMA_BASE_URL=http://localhost:11434
#AGENT_JWT_SECRET=change-me-in-production
